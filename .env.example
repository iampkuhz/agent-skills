# 说明：
# 1) 本文件是本仓库统一环境变量模板（单一维护入口）。
# 2) 仅列“脚本真实读取”或“测试/示例明确使用”的变量。
# 3) 变量后会标注使用位置（skill / 脚本）。
# 4) 同类场景统一命名：
#    - 视频下载类统一 `AGENT_VIDEO_*`，cookie 按站点区分
#    - PlantUML 类统一 `AGENT_PLANTUML_SERVER_PORT`
# 5) 不在各个 skill 下分散维护 `.env.example`。

# ===== 安装包装器 =====

# 使用场景：AGENT=codex 时，指定 codex 的 home。
# 使用位置：scripts/install_skills.sh
CODEX_HOME=$HOME/.codex

# 使用场景：AGENT=openclaw 时，指定 openclaw 的 home。
# 使用位置：scripts/install_skills.sh
OPENCLAW_HOME=$HOME/.openclaw

# ===== 通用技能配置（视频类） =====

# 使用场景：浏览器 profile 登录态（Bilibili / YouTube）。
# 使用位置：
# - skills/integration/feipi-video-read-url/scripts/download_youtube.sh
# - skills/integration/feipi-video-read-url/scripts/download_bilibili.sh
# 常见值：chrome:Default / chrome:Profile 1 / brave:Default
AGENT_CHROME_PROFILE=chrome:Profile 1

# 使用场景：YouTube cookies 文件（Netscape Cookie File）。
# 使用位置：skills/integration/feipi-video-read-url/scripts/download_youtube.sh
AGENT_YOUTUBE_COOKIE_FILE=$HOME/.config/yt-dlp/cookies.youtube.txt

# 使用场景：Bilibili cookies 文件（Netscape Cookie File）。
# 使用位置：skills/integration/feipi-video-read-url/scripts/download_bilibili.sh
AGENT_BILIBILI_COOKIE_FILE=$HOME/.config/yt-dlp/cookies.bilibili.txt

# 使用场景：视频站点代理端口（仅直连与默认 7890 均失败时使用）。
# 使用位置：
# - skills/integration/feipi-video-read-url/scripts/download_youtube.sh
# - skills/integration/feipi-video-read-url/scripts/download_bilibili.sh
AGENT_VIDEO_PROXY_PORT=7890

# ===== PlantUML 配置 =====

# 使用场景：本地 PlantUML server 端口。
# 使用位置：
# - skills/diagram/feipi-plantuml-generate-diagram/scripts/check_render.sh
# - skills/diagram/feipi-plantuml-generate-diagram/assets/server_candidates.txt
# - skills/diagram/feipi-plantuml-generate-architecture-diagram/scripts/check_render.sh
# - skills/diagram/feipi-plantuml-generate-architecture-diagram/assets/server_candidates.txt
# - skills/diagram/feipi-plantuml-generate-sequence-diagram/scripts/check_render.sh
# - skills/diagram/feipi-plantuml-generate-sequence-diagram/assets/server_candidates.txt
AGENT_PLANTUML_SERVER_PORT=8199

# ===== LiteLLM 网关配置 =====

# 使用场景：LiteLLM spend logs 清理批次大小。
# 使用位置：tools/gateway/litellm/compose/docker-compose.yml
SPEND_LOG_CLEANUP_BATCH_SIZE=200

# 使用场景：LiteLLM spend logs 单轮清理批次数。
# 使用位置：tools/gateway/litellm/compose/docker-compose.yml
SPEND_LOG_RUN_LOOPS=50

# ===== Session Browser 配置 =====

# 使用场景：session-browser 读取 Claude Code 会话目录。
# 使用位置：tools/session-browser/src/session_browser/config.py
CLAUDE_DATA_DIR=$HOME/.claude

# 使用场景：session-browser 读取 Codex 会话目录。
# 使用位置：tools/session-browser/src/session_browser/config.py
CODEX_DATA_DIR=$HOME/.codex

# 使用场景：session-browser 读取 Qoder 会话目录。
# 使用位置：tools/session-browser/src/session_browser/config.py
QODER_DATA_DIR=$HOME/.qoder

# 使用场景：session-browser 本地前台测试 SQLite 索引目录。
# 使用位置：tools/session-browser/src/session_browser/config.py
INDEX_DIR=$HOME/.local/share/feipi/session-browser/local-test-index

# 使用场景：session-browser 本地前台测试服务监听地址与端口。
# 使用位置：tools/session-browser/src/session_browser/config.py
SERVER_HOST=127.0.0.1
SERVER_PORT=18999

# 使用场景：本地前台和 Podman 容器日志级别。
# 使用位置：
# - tools/session-browser/src/session_browser/config.py
# - tools/session-browser/scripts/session-browser.sh
SESSION_BROWSER_LOG_LEVEL=INFO

# 使用场景：session-browser 本地依赖虚拟环境目录。
# 使用位置：tools/session-browser/scripts/session-browser.sh
SESSION_BROWSER_VENV_DIR=tools/session-browser/.venv

# 使用场景：session-browser 本地前台 serve/scan 设置；与 Podman 端口/数据库隔离。
# 使用位置：tools/session-browser/scripts/session-browser.sh
SESSION_BROWSER_LOCAL_HOST=127.0.0.1
SESSION_BROWSER_LOCAL_PORT=18999
SESSION_BROWSER_LOCAL_DATA_DIR=$HOME/.local/share/feipi/session-browser/local-test-index

# 使用场景：本地 Podman 镜像仓库名。
# 使用位置：tools/session-browser/scripts/session-browser.sh
SESSION_BROWSER_IMAGE_REPO=localhost/feipi/session-browser

# 使用场景：本地 Podman 容器名。
# 使用位置：tools/session-browser/scripts/session-browser.sh
SESSION_BROWSER_CONTAINER_NAME=session-browser

# 使用场景：本地 Podman 映射到宿主机的端口。
# 使用位置：tools/session-browser/scripts/session-browser.sh
SESSION_BROWSER_HOST_PORT=8899

# 使用场景：本地 Podman 持久化索引目录。
# 使用位置：tools/session-browser/scripts/session-browser.sh
SESSION_BROWSER_DATA_DIR=$HOME/.local/share/feipi/session-browser/index

# 使用场景：session-browser 容器启动时先做一次增量扫描，避免首次启动空库。
# 使用位置：tools/session-browser/src/session_browser/cli.py
SESSION_BROWSER_STARTUP_SCAN=1
