{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Style Lock",
  "description": "PPT 风格锁定配置，定义字体、颜色、间距、最小字号、区域样式和禁止模式",
  "type": "object",
  "required": ["name", "canvas", "colors", "min_font_sizes", "prohibited"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "canvas": {
      "type": "object",
      "required": ["width_in", "height_in"],
      "properties": {
        "width_in": { "type": "number", "minimum": 1 },
        "height_in": { "type": "number", "minimum": 1 },
        "aspect_ratio": { "type": "string", "enum": ["16:9", "4:3"] }
      }
    },
    "fonts": {
      "type": "object",
      "properties": {
        "default": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "title": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "monospace": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "colors": {
      "type": "object",
      "required": ["primary", "secondary", "text", "background"],
      "properties": {
        "primary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "secondary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "accent": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "text": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "text_secondary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "background": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "surface": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "border": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "semantic": {
          "type": "object",
          "patternProperties": {
            "^[a-z_]+$": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
          }
        },
        "pale": {
          "type": "object",
          "patternProperties": {
            "^[a-z]+$": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
          }
        }
      }
    },
    "spacing": {
      "type": "object",
      "properties": {
        "page_margin_in": { "type": "number", "minimum": 0 },
        "section_gap_in": { "type": "number", "minimum": 0 },
        "card_gap_in": { "type": "number", "minimum": 0 },
        "table_cell_padding_in": { "type": "number", "minimum": 0 }
      }
    },
    "min_font_sizes": {
      "type": "object",
      "required": ["title", "body"],
      "properties": {
        "title": { "type": "number", "minimum": 1 },
        "subtitle": { "type": "number", "minimum": 1 },
        "region_title": { "type": "number", "minimum": 1 },
        "body": { "type": "number", "minimum": 1 },
        "table_cell": { "type": "number", "minimum": 1 },
        "label": { "type": "number", "minimum": 1 },
        "caption": { "type": "number", "minimum": 1 },
        "footer": { "type": "number", "minimum": 1 }
      }
    },
    "font_sizes": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": { "type": "number", "minimum": 1 }
      }
    },
    "region_style": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": { "type": "object" }
      }
    },
    "card_style": {
      "type": "object",
      "properties": {
        "corner_radius": { "type": "number", "minimum": 0 },
        "border_color": { "type": "string" },
        "bg": { "type": "string" },
        "title_color": { "type": "string" },
        "body_color": { "type": "string" },
        "padding_in": { "type": "number", "minimum": 0 }
      }
    },
    "connector_style": {
      "type": "object",
      "properties": {
        "color": { "type": "string" },
        "width_pt": { "type": "number", "minimum": 0.5 },
        "arrow_type": { "type": "string" },
        "highlight_color": { "type": "string" }
      }
    },
    "table_style": {
      "type": "object",
      "properties": {
        "header_bg": { "type": "string" },
        "header_text": { "type": "string" },
        "row_alt_bg": { "type": "string" },
        "border_color": { "type": "string" },
        "max_rows": { "type": "integer", "minimum": 1 },
        "max_cols": { "type": "integer", "minimum": 1 },
        "cell_max_chars": { "type": "integer", "minimum": 1 },
        "highlight_col_color": { "type": "string" }
      }
    },
    "prohibited": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "density_limits": {
      "type": "object",
      "properties": {
        "max_main_visuals": { "type": "integer", "minimum": 1 },
        "max_bullets": { "type": "integer", "minimum": 1 },
        "max_kpi_cards": { "type": "integer", "minimum": 1 },
        "max_flow_steps": { "type": "integer", "minimum": 1 },
        "max_architecture_nodes": { "type": "integer", "minimum": 1 },
        "max_table_rows": { "type": "integer", "minimum": 1 },
        "max_table_cols": { "type": "integer", "minimum": 1 },
        "max_comparison_objects": { "type": "integer", "minimum": 1 },
        "max_comparison_dimensions": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
