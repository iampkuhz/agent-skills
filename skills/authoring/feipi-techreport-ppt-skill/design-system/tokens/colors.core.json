{
  "id": "colors.core",
  "version": "1.0.0",
  "description": "CTO 技术汇报默认颜色集合。保持克制、低饱和、工程化，不使用彩虹色或大面积渐变。",
  "tokens": {
    "brand": {
      "primary": "#1B2A4A",
      "secondary": "#1A73E8",
      "accent": "#1A73E8"
    },
    "text": {
      "primary": "#1B2A4A",
      "secondary": "#5F6368",
      "muted": "#80868B",
      "inverse": "#FFFFFF"
    },
    "surface": {
      "page": "#FFFFFF",
      "panel": "#F8F9FA",
      "panel_blue": "#E8F0FE",
      "panel_green": "#E6F4EA",
      "panel_orange": "#FEF7E0",
      "panel_red": "#FCE8E6"
    },
    "border": {
      "default": "#DADCE0",
      "strong": "#AEB4BC",
      "subtle": "#ECEFF3"
    },
    "semantic": {
      "success": "#0D652D",
      "warning": "#E37400",
      "danger": "#C5221F",
      "info": "#1A73E8",
      "neutral": "#5F6368"
    },
    "data": {
      "series_1": "#1A73E8",
      "series_2": "#0D652D",
      "series_3": "#E37400",
      "series_4": "#5F6368",
      "negative": "#C5221F"
    }
  },
  "rules": {
    "max_primary_colors_per_slide": 3,
    "avoid": [
      "full_page_gradient",
      "rainbow_heatmap",
      "decorative_orbs",
      "low_contrast_text"
    ]
  }
}

