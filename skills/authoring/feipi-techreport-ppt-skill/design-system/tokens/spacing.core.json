{
  "id": "spacing.core",
  "version": "1.0.0",
  "description": "页面网格、边距、区块间距和组件内边距 token。",
  "canvas": {
    "preset": "wide_16_9",
    "width_in": 13.33,
    "height_in": 7.5
  },
  "page": {
    "margin_in": 0.5,
    "header_height_in": 0.8,
    "footer_height_in": 0.42,
    "safe_gap_in": 0.1
  },
  "grid": {
    "columns": 12,
    "gutter_in": 0.12,
    "section_gap_in": 0.2,
    "card_gap_in": 0.15
  },
  "padding_in": {
    "text_box": [0.07, 0.1, 0.07, 0.1],
    "card": [0.1, 0.12, 0.1, 0.12],
    "table_cell": [0.03, 0.06, 0.03, 0.06],
    "diagram_node": [0.06, 0.08, 0.06, 0.08]
  },
  "rules": {
    "min_element_gap_in": 0.1,
    "min_region_gap_in": 0.16,
    "footer_must_not_overlap_body": true
  }
}

