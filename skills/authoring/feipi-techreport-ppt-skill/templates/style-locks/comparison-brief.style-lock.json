{
  "$schema": "../../schemas/style-lock.schema.json",
  "name": "comparison-brief",
  "description": "对比简报风格：聚焦差异、高亮关键决策点、避免全量矩阵",
  "version": "1.0.0",
  "canvas": {
    "width_in": 13.33,
    "height_in": 7.5,
    "aspect_ratio": "16:9"
  },
  "fonts": {
    "default": ["Kaiti SC", "PingFang SC", "Microsoft YaHei", "SimHei", "sans-serif"],
    "title": ["Kaiti SC", "PingFang SC", "Microsoft YaHei", "SimHei", "sans-serif"],
    "monospace": ["Menlo", "Consolas", "Monaco", "monospace"]
  },
  "colors": {
    "primary": "#1B2A4A",
    "secondary": "#1A73E8",
    "accent": "#1A73E8",
    "text": "#1B2A4A",
    "text_secondary": "#5F6368",
    "background": "#FFFFFF",
    "surface": "#F8F9FA",
    "border": "#DADCE0",
    "semantic": {
      "success": "#0D652D",
      "warning": "#E37400",
      "danger": "#C5221F",
      "info": "#1A73E8"
    },
    "pale": {
      "blue": "#E8F0FE",
      "orange": "#FEF7E0",
      "red": "#FCE8E6",
      "green": "#E6F4EA"
    }
  },
  "spacing": {
    "page_margin_in": 0.5,
    "section_gap_in": 0.2,
    "card_gap_in": 0.15,
    "table_cell_padding_in": 0.05
  },
  "min_font_sizes": {
    "title": 26,
    "subtitle": 14,
    "region_title": 13,
    "body": 10,
    "table_cell": 8.5,
    "label": 8.5,
    "caption": 7.5,
    "footer": 7.5
  },
  "font_sizes": {
    "title": 28,
    "subtitle": 14,
    "region_title": 13,
    "body": 10,
    "label": 9,
    "caption": 9,
    "takeaway": 13,
    "footer": 8.5,
    "kpi_value": 16,
    "kpi_label": 10,
    "table_header": 10,
    "table_cell": 9
  },
  "region_style": {
    "header": {
      "bg": "background",
      "max_height_pct": 15,
      "border_bottom": true
    },
    "main_visual": {
      "bg": "surface",
      "min_width_pct": 50,
      "max_width_pct": 65
    },
    "evidence_panel": {
      "bg": "surface",
      "width_pct_range": [20, 30]
    },
    "footer_takeaway": {
      "bg": "background",
      "min_height_pct": 8,
      "max_height_pct": 12,
      "border_top": true
    }
  },
  "card_style": {
    "corner_radius": 0,
    "border_color": "border",
    "bg": "white",
    "title_color": "primary",
    "body_color": "text",
    "padding_in": 0.12,
    "highlight_border": "secondary"
  },
  "connector_style": {
    "color": "secondary",
    "width_pt": 1.5,
    "arrow_type": "triangle",
    "highlight_color": "accent"
  },
  "table_style": {
    "header_bg": "primary",
    "header_text": "background",
    "row_alt_bg": "surface",
    "border_color": "border",
    "max_rows": 5,
    "max_cols": 4,
    "cell_max_chars": 50,
    "cell_max_lines": 2,
    "highlight_col_color": "pale.blue",
    "diff_highlight": "accent"
  },
  "prohibited": [
    "full_page_gradient",
    "excessive_decoration",
    "rainbow_heatmap",
    "multiple_primary_colors",
    "mixed_font_families",
    "full_page_image_only",
    "no_conclusion_zone",
    "overlapping_elements",
    "font_size_below_minimum",
    "full_comparison_matrix_without_focus",
    "more_than_one_highlight_column"
  ],
  "density_limits": {
    "max_main_visuals": 1,
    "max_bullets": 5,
    "max_kpi_cards": 4,
    "max_comparison_objects": 4,
    "max_comparison_dimensions": 5,
    "max_table_rows": 5,
    "max_table_cols": 4,
    "highlight_columns": 1
  }
}
