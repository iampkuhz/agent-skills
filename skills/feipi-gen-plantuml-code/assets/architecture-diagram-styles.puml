' 架构组件图标准样式库
' 用法：!include architecture-diagram-styles.puml

skinparam componentStyle rectangle
skinparam shadowing false

' 纵向布局
top to bottom direction
skinparam nodesep 25
skinparam ranksep 35

' 配色方案 - 组件（蓝色系）
skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
}

' 配色方案 - 数据存储（绿色系）
skinparam database {
    BackgroundColor #C8E6C9
    BorderColor #2E7D32
}

' 配色方案 - 外部角色（灰色系）
skinparam actor {
    BackgroundColor #E0E0E0
    BorderColor #424242
}

' 配色方案 - 数据对象（黄色系）
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

' 配色方案 - 接口（橙色系）
skinparam interface {
    BackgroundColor #FFE0B2
    BorderColor #E65100
}

' 配色方案 - 队列（紫色系）
skinparam queue {
    BackgroundColor #E1BEE7
    BorderColor #7B1FA2
}

' 分层背景色
skinparam package {
    BackgroundColor #F0F4F8
    BorderColor #5A6C7D
}
