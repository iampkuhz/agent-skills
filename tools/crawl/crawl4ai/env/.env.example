# Crawl4AI Service 环境变量模板（占位）
# 状态：⏳ 预留位置，待实现

# ==============================================================================
# [可选] Crawl4AI 基础配置
# ==============================================================================

# Crawl4AI 服务端口（未来使用）
# CRAWL4AI_PORT=8888

# Crawl4AI API 密钥（未来使用）
# CRAWL4AI_API_KEY=your-api-key

# ==============================================================================
# [可选] Playwright 配置
# ==============================================================================

# 浏览器类型（chromium, firefox, webkit）
# CRAWL4AI_BROWSER=chromium

# 无头模式
# CRAWL4AI_HEADLESS=true

# ==============================================================================
# [可选] 代理配置
# ==============================================================================

# HTTP 代理（用于访问受限网站）
# HTTP_PROXY=http://host.containers.internal:7890
# HTTPS_PROXY=http://host.containers.internal:7890
