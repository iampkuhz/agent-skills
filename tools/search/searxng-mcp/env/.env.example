# SearXNG MCP Service 环境变量模板
# 使用说明：
# 1. 复制此文件：cp tools/search/searxng-mcp/env/.env.example tools/search/searxng-mcp/env/.env
# 2. 根据实际情况编辑

# ==============================================================================
# [必需] SearXNG 服务配置
# ==============================================================================

# SearXNG 服务地址（默认：http://localhost:8873）
# 确保 SearXNG 服务正在运行
SEARXNG_BASE_URL=http://localhost:8873

# HTTP 请求超时（秒）
SEARXNG_TIMEOUT=30.0

# ==============================================================================
# [可选] MCP 服务配置
# ==============================================================================

# HTTP 模式下的服务端口（默认：8888）
# 仅在 Streamable HTTP 模式下使用
SEARXNG_MCP_PORT=8888

# 日志级别（DEBUG, INFO, WARNING, ERROR）
SEARXNG_MCP_LOG_LEVEL=INFO

# Transport 模式（stdio, streamable-http）
# stdio: 通过 stdin/stdout 通信（Claude Code 推荐）
# streamable-http: 通过 HTTP 通信
SEARXNG_MCP_TRANSPORT=stdio
