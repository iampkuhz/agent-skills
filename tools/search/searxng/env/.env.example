# SearXNG 环境变量模板
# 使用说明：
# 1. 复制此文件：cp tools/search/searxng/env/.env.example tools/search/searxng/env/.env
# 2. 根据实际情况编辑（当前 SearXNG 配置主要在 settings.yml 中）

# ==============================================================================
# [可选] SearXNG 基础配置
# ==============================================================================

# SearXNG 访问端口（默认：8873）
# 如需修改，请同时调整 compose/docker-compose.yml 中的端口映射
SEARXNG_PORT=8873

# SearXNG 密钥（用于会话加密，生产环境应使用随机字符串）
# 生成命令：openssl rand -hex 32
SEARXNG_SECRET_KEY=$(openssl rand -hex 32)

# ==============================================================================
# [可选] 代理配置（用于访问受限服务）
# ==============================================================================

# 代理地址（根据实际网络环境修改）
# HTTP_PROXY=http://host.containers.internal:7890
# HTTPS_PROXY=http://host.containers.internal:7890
