# Claude Code data directory
CLAUDE_DATA_DIR=~/.claude

# Codex data directory
CODEX_DATA_DIR=~/.codex

# Qoder data directory
QODER_DATA_DIR=~/.qoder

# Index storage directory
INDEX_DIR=~/.cache/agent-session-browser

# Server bind address
SERVER_HOST=0.0.0.0

# Server port
SERVER_PORT=8899

# Foreground/container log level: DEBUG, INFO, WARNING, ERROR
SESSION_BROWSER_LOG_LEVEL=INFO

# Local Podman image repository and container settings
SESSION_BROWSER_IMAGE_REPO=localhost/feipi/session-browser
SESSION_BROWSER_CONTAINER_NAME=session-browser
SESSION_BROWSER_HOST_PORT=8899
SESSION_BROWSER_DATA_DIR=~/.local/share/feipi/session-browser/index
SESSION_BROWSER_STARTUP_SCAN=1
